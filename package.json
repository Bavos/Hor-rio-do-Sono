{
  "name": "ia-conversacional-riscos-remotion",
  "version": "1.0.0",
  "private": true,
  "description": "Vídeo vertical Remotion de 30 segundos sobre riscos psicológicos do uso excessivo de IA conversacional.",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "studio": "remotion studio remotion/src/index.ts",
    "render": "npx remotion render remotion/src/index.ts MainComposition downloads/video-final.mp4 --codec=h264 --overwrite",
    "render:ci": "mkdir -p downloads && npm run render",
    "validate": "node scripts/validate-project.mjs",
    "preview:data": "node backend/server.js"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.320",
    "@remotion/renderer": "^4.0.320",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "remotion": "^4.0.320",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.19",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
